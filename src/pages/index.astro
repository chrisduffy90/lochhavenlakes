---
import '../styles/global.css';

const mapboxToken = import.meta.env.PUBLIC_MAPBOX_TOKEN;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Loch Haven Lakes</title>
  <link href="https://api.mapbox.com/mapbox-gl-js/v3.17.0/mapbox-gl.css" rel="stylesheet">
  <script src="https://api.mapbox.com/mapbox-gl-js/v3.17.0/mapbox-gl.js" is:inline></script>
</head>
<body>

  <nav>
    <span class="site-name">Loch Haven Lakes</span>
    <div class="nav-links">
      <a href="#mission" class="nav-text-link">About</a>
      <a href="#report" class="nav-text-link">Report</a>
      <a href="/resources" class="nav-text-link">Resources</a>
      <a href="#signup" class="nav-cta">Stay Updated</a>
      <button class="hamburger" id="hamburger" aria-label="Toggle menu" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </nav>

  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <a href="#mission">About</a>
    <a href="#report">Report</a>
    <a href="/resources">Resources</a>
  </div>

  <!-- MAP -->
  <section id="map-section">
    <div id="map"></div>

    <!-- Desktop overlay -->
    <div class="map-overlay">
      <p>Monitoring water quality, wildlife, and environmental health across Orlando's urban lakes.</p>
      <div class="lake-tags">
        <span class="lake-tag" data-lake="Lake Formosa">Lake Formosa</span>
        <span class="lake-tag" data-lake="Lake Rowena">Lake Rowena</span>
        <span class="lake-tag" data-lake="Lake Estelle">Lake Estelle</span>
        <span class="lake-tag" data-lake="Lake Sue">Lake Sue</span>
        <span class="lake-tag" data-lake="Lake Winyah">Lake Winyah</span>
      </div>
      <a href="/lakes" class="lakes-link">Learn more about the lakes →</a>
    </div>

    <!-- Mobile: tap to interact prompt -->
    <div class="map-touch-prompt" id="map-touch-prompt">Tap to explore map</div>

    <!-- Mobile bottom sheet -->
    <div class="map-bottom-sheet">
      <div class="drag-handle"></div>
      <p>Monitoring water quality, wildlife, and environmental health across Orlando's urban lakes.</p>
      <div class="lake-tags-scroll">
        <span class="lake-tag" data-lake="Lake Formosa">Lake Formosa</span>
        <span class="lake-tag" data-lake="Lake Rowena">Lake Rowena</span>
        <span class="lake-tag" data-lake="Lake Estelle">Lake Estelle</span>
        <span class="lake-tag" data-lake="Lake Sue">Lake Sue</span>
        <span class="lake-tag" data-lake="Lake Winyah">Lake Winyah</span>
      </div>
      <a href="/lakes" class="lakes-link">Learn more about the lakes →</a>
    </div>
  </section>

  <!-- MISSION -->
  <section id="mission">
    <div class="mission-inner fade-in">
      <span class="mission-label">Our Mission</span>
      <div class="mission-text">
        <h2>Bridging the gap between community observation and civic action</h2>
        <p>The Loch Haven lake chain runs through the heart of Orlando, yet responsibility for its health is divided across multiple agencies. Fishing litter, water quality issues, and wildlife distress often go unreported — not because people don't care, but because they don't know who to call.</p>
        <p>This platform exists to change that. Submit a report, track lake health over time, and connect with the right agency the first time.</p>
        <div class="jurisdiction-note">
          <strong>Who manages what?</strong> The parks department oversees the shoreline, stormwater manages the first few feet of water, and Florida Fish &amp; Wildlife covers the rest. A full jurisdiction guide is coming soon.
        </div>
      </div>
    </div>
  </section>

  <!-- REPORT -->
  <section>
    <div id="report">
      <div class="section-header fade-in">
        <span class="section-label">Take Action</span>
        <div>
          <h2>See something.<br>Report it.</h2>
          <p>Every report builds a clearer picture of lake health over time and routes directly to the right agency.</p>
        </div>
      </div>
      <div class="report-grid fade-in">
        <a href="#" class="report-card">
          <div class="report-icon">🪱</div>
          <h3>Fishing Litter</h3>
          <p>Monofilament line, hooks, bait containers, and tackle left at the water's edge.</p>
          <span class="coming-soon-badge">Coming Soon</span>
        </a>
        <a href="#" class="report-card">
          <div class="report-icon">🦅</div>
          <h3>Wildlife Distress</h3>
          <p>Injured birds, entangled animals, or unusual wildlife behavior near the lakes.</p>
          <span class="coming-soon-badge">Coming Soon</span>
        </a>
        <a href="#" class="report-card">
          <div class="report-icon">💧</div>
          <h3>Water Quality</h3>
          <p>Algae blooms, discoloration, unusual odor, or visible pollution in the water.</p>
          <span class="coming-soon-badge">Coming Soon</span>
        </a>
      </div>
    </div>
  </section>

  <!-- SIGNUP -->
  <section id="signup">
    <div class="signup-inner">
      <div class="signup-text fade-in">
        <h2>Stay in the loop</h2>
        <p>Get notified when the reporting platform launches and when lake health updates are published for your area.</p>
      </div>
      <form class="signup-form fade-in" id="signup-form">
        <input type="text" placeholder="Your name" id="signup-name">
        <input type="email" placeholder="Email address" id="signup-email" required>
        <button type="submit">Notify Me When We Launch →</button>
      </form>
    </div>
  </section>

  <footer>
    <span>© 2026 Loch Haven Lakes</span>
    <span>Orlando, Florida</span>
  </footer>

  <script define:vars={{ mapboxToken }}>
    mapboxgl.accessToken = mapboxToken;

    const map = new mapboxgl.Map({
      container: 'map',
      style: 'mapbox://styles/chrisduffy90/cmmgqwd3h003101qn19rk2mdw',
      center: [-81.3640, 28.5740],
      zoom: 14.8,
      pitch: 30,
      scrollZoom: false,
    });

    map.addControl(new mapboxgl.NavigationControl(), 'bottom-right');

    const lakes = [
      { name: 'Lake Formosa', coords: [-81.36973539513252, 28.568350215338864] },
      { name: 'Lake Rowena', coords: [-81.3600932586758, 28.570678173361642] },
      { name: 'Lake Estelle', coords: [-81.36579300695567, 28.574994295707267] },
      { name: 'Lake Sue', coords: [-81.35439992564169, 28.577123080993033] },
      { name: 'Lake Winyah', coords: [-81.36850798530743, 28.578398939361946] },
    ];

    const markerEls = {};

    lakes.forEach(lake => {
      const el = document.createElement('div');
      el.style.cssText = `
        width: 10px;
        height: 10px;
        background: #4a5568;
        border: 2px solid white;
        border-radius: 50%;
        box-shadow: 0 2px 6px rgba(0,0,0,0.3);
        cursor: pointer;
      `;
      markerEls[lake.name] = el;
      el.addEventListener('animationend', () => el.classList.remove('marker-bounce'));

      new mapboxgl.Marker(el)
        .setLngLat(lake.coords)
        .setPopup(new mapboxgl.Popup({ offset: 15 }).setHTML(`<strong>${lake.name}</strong>`))
        .addTo(map);
    });

    document.querySelectorAll('.lake-tag[data-lake]').forEach(tag => {
      tag.addEventListener('mouseenter', () => {
        const el = markerEls[tag.dataset.lake];
        if (!el) return;
        el.classList.remove('marker-bounce');
        void el.offsetWidth;
        el.classList.add('marker-bounce');
      });
    });

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) entry.target.classList.add('visible');
      });
    }, { threshold: 0.15 });

    document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));

    document.getElementById('signup-form').addEventListener('submit', async (e) => {
      e.preventDefault();

      const name = document.getElementById('signup-name').value;
      const email = document.getElementById('signup-email').value;
      const btn = e.target.querySelector('button');

      btn.textContent = 'Submitting...';
      btn.disabled = true;

      try {
        const response = await fetch('https://lochhavenlakes.onrender.com/signup', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, email })
        });

        if (response.ok) {
          btn.textContent = "You're on the list ✓";
          btn.style.opacity = '0.6';
        } else {
          btn.textContent = 'Something went wrong. Try again.';
          btn.disabled = false;
        }
      } catch (error) {
        btn.textContent = 'Could not connect. Try again.';
        btn.disabled = false;
      }
    });

    // --- Hamburger menu ---
    const hamburger = document.getElementById('hamburger');
    const mobileMenu = document.getElementById('mobile-menu');

    if (hamburger && mobileMenu) {
      hamburger.addEventListener('click', (e) => {
        e.stopPropagation();
        const isOpen = mobileMenu.classList.toggle('open');
        hamburger.classList.toggle('open', isOpen);
        hamburger.setAttribute('aria-expanded', String(isOpen));
        mobileMenu.setAttribute('aria-hidden', String(!isOpen));
      });

      document.addEventListener('click', (e) => {
        if (!mobileMenu.contains(e.target) && !hamburger.contains(e.target)) {
          mobileMenu.classList.remove('open');
          hamburger.classList.remove('open');
          hamburger.setAttribute('aria-expanded', 'false');
          mobileMenu.setAttribute('aria-hidden', 'true');
        }
      });

      mobileMenu.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          mobileMenu.classList.remove('open');
          hamburger.classList.remove('open');
          hamburger.setAttribute('aria-expanded', 'false');
          mobileMenu.setAttribute('aria-hidden', 'true');
        });
      });
    }

    // --- Mobile map touch fix ---
    const touchPrompt = document.getElementById('map-touch-prompt');

    if (window.innerWidth <= 768) {
      map.dragPan.disable();
      map.touchZoomRotate.disable();

      if (touchPrompt) {
        touchPrompt.addEventListener('click', () => {
          map.dragPan.enable();
          map.touchZoomRotate.enable();
          touchPrompt.style.display = 'none';
        });
      }
    }
  </script>

</body>
</html>
